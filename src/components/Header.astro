---
import { EMAIL, SUBSTACK, TELEGRAM, X } from "../consts";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-50 -mx-4 mb-12 border-b border-zinc-200/80 bg-white/85 px-4 py-3 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/85"
  transition:name="header"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 text-sm">
    <a href="/" class="font-semibold tracking-[-0.02em] text-zinc-950 dark:text-white">
      Shad.ai
    </a>
    <div class="hidden items-center gap-5 md:flex">
      <a href="/#work">work</a>
      <a href="/#proof">proof</a>
      <a href="/#offers">cost</a>
      <a href="/#receipts">receipts</a>
      <a href={SUBSTACK} target="_blank">Substack</a>
      <a href={TELEGRAM} target="_blank">Telegram</a>
      <a href={X} target="_blank">X</a>
    </div>
    <div class="flex items-center gap-3">
      <a
        href={`mailto:${EMAIL}?subject=Working%20with%20Shad`}
        class="rounded-md bg-zinc-950 px-3 py-2 text-xs font-medium text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
      >
        book / enquire
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  nav a {
    @apply text-zinc-500 transition hover:text-zinc-950 hover:underline dark:text-zinc-400 dark:hover:text-white;
  }
</style>
